# ===========================================
# MCP Server Configuration
# ===========================================

# Server Configuration
MCP_PORT=3000

# ===========================================
# GitHub Authentication
# ===========================================
# Add your actual tokens here (never commit real tokens)

# Default GitHub token for public repositories
GITHUB_TOKEN=your_github_personal_access_token_here

# Specific tokens for different use cases
GITHUB_TOKEN_PUBLIC=your_public_token_here
GITHUB_TOKEN_PRIVATE=your_private_token_here
GITHUB_TOKEN_ENTERPRISE=your_enterprise_token_here
GITHUB_TOKEN_PERSONAL=your_personal_token_here

# GitHub webhook secret for API endpoints
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# Network & Performance Settings
# ===========================================
FETCH_TIMEOUT=10000          # Request timeout in milliseconds (default: 10s)
FETCH_RETRIES=3              # Number of retry attempts (default: 3)
FETCH_RETRY_DELAY=1000       # Initial retry delay in milliseconds (default: 1s)
MAX_REFERENCE_DEPTH=2        # Maximum recursion depth for external references (default: 2)

# Cache settings
CACHE_TTL=300                # Cache TTL in seconds (default: 5 minutes)