# Omni MCP Hub Configuration Example
# Copy to mcp-sources.yaml and customize

sources:
  # GitHub repository examples
  - url: https://github.com/microsoft/vscode
    token: ${GITHUB_TOKEN}
    
  - url: github:owner/repo@main
    token: ${GITHUB_TOKEN_PRIVATE}
    
  # Local directory examples  
  - url: /path/to/local/project
  - url: ./relative/path

# Optional: Customize file patterns (defaults shown)
# files:
#   patterns:
#     - "CLAUDE.md"
#     - "*.claude.md"
#   max_size: 1048576  # 1MB

# Optional: Adjust fetch settings (defaults shown)
# fetch:
#   timeout: 30000      # 30 seconds
#   retries: 3
#   retry_delay: 1000   # 1 second
#   max_depth: 3        # Max external reference depth

# Optional: Custom security rules
# security:
#   content_validation:
#     enabled: true
#     reject_patterns:
#       - "custom\\s+dangerous\\s+pattern"
#     additional_keywords:
#       - "forbidden_word"