{
  "name": "omni-mcp-hub",
  "version": "1.0.0",
  "description": "Universal MCP server for GitHub repositories and knowledge integration",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:manual": "node test-mcp-client.js",
    "cli": "ts-node src/cli-helpers.ts"
  },
  "keywords": [
    "mcp",
    "github",
    "knowledge",
    "context"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^2.7.0",
    "simple-git": "^3.22.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.8.0",
    "@types/node-fetch": "^2.6.11",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.9",
    "eventsource": "^2.0.2",
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
