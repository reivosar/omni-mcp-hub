# Omni MCP Hub Configuration Example
# Copy to mcp-sources.yaml and customize as needed
# Most settings are handled via environment variables

sources:
  # GitHub repository examples
  - url: https://github.com/microsoft/vscode
    token: ${GITHUB_TOKEN}
    
  - url: github:owner/repo@main
    token: ${GITHUB_TOKEN}
    
  # Local directory examples  
  - url: /path/to/local/project
  - url: ./relative/path

# File settings (optional - these are defaults)
files:
  patterns:
    - "CLAUDE.md"
    - "*.claude.md"
    - "docs/CLAUDE.md"
  max_size: 1048576  # 1MB max file size

# Fetch settings (optional)
fetch:
  timeout: 30000      # 30 seconds
  retries: 3
  retry_delay: 1000   # 1 second
  max_depth: 3        # Max depth for external references

# Cache settings (optional)
cache:
  ttl: 300000  # 5 minutes cache TTL

# Security settings (optional)
security:
  content_validation:
    enabled: true  # Enable/disable content validation
    # Custom rejection patterns (regex)
    reject_patterns:
      - "custom\\s+dangerous\\s+pattern"
      - "another\\s+pattern"
    # Additional keywords to block (3+ matches trigger rejection)
    additional_keywords:
      - "forbidden_word1"
      - "forbidden_word2"